@startuml
title Gadash Bot — Activity Diagram (Submit Work Entry)

skinparam backgroundColor #ffffff
skinparam activity {
  BackgroundColor #e8f0fb
  BorderColor #3578c8
  ArrowColor #1a2f4e
  StartColor #1a2f4e
  EndColor #1a2f4e
  DiamondBackgroundColor #fef3c7
  DiamondBorderColor #d97706
  FontColor #000000
}

start
:User sends /start to bot;
:Bot displays main MENU;
:User selects "Submit New Work Entry";

:Bot requests client name;
:User enters client name;

repeat
  :Bot requests date\n(YYYY-MM-DD or "today");
  :User enters date;
  if (Valid date?) then (yes)
  else (no)
    :Bot shows error, requests again;
  endif
repeat while (Valid date?) is (no)

:Bot shows keyboard:\nPlowing / Spraying / Harvesting / Disking / Other;
:User selects task type;

:Bot requests field name;
:User enters field name;

:Bot requests crop type;
if (User skips?) then (no)
  :User enters crop;
endif

:Bot requests quantity;
:User enters quantity;

:Bot requests work hours;
if (User skips?) then (no)
  :User enters hours;
endif

:Bot requests equipment;
:User enters equipment;

:Bot requests operator name;
:User enters operator;

:Bot requests notes (optional — photo allowed);
if (User skips?) then (no)
  :User enters notes / attaches photo;
endif

:WorkEntry.__post_init__() — validate required fields;
:Bot displays full summary for confirmation;

if (User confirmed?) then (yes)
  :create_entry()\nappend_row_to_gsheet() + _log_audit("add");
  :Bot sends success message;
else (no / /cancel)
  :Bot sends cancellation message;
endif

:Return to MENU;
stop

note right
  Other menu options:
  • View Last 5 Entries
  • Search by Client
  • Undo Last Entry (/undo)
  • Exit
end note

@enduml
