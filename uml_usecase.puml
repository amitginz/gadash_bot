@startuml
title Gadash Management System — Use Case Diagram

left to right direction
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #e8f0fb
  BorderColor #3578c8
  ArrowColor #1a2f4e
}
skinparam actor {
  BackgroundColor #f5f7fa
  BorderColor #1a2f4e
}

actor "עובד שדה\n(Telegram)" as FieldWorker
actor "מנהל\n(Web)" as Manager
actor "Google Sheets" as GSheets

rectangle "Gadash Management System" {
  usecase "הזנת עבודה חדשה" as UC1
  usecase "צפייה ב-5 עבודות אחרונות" as UC2
  usecase "צפייה בכל העבודות" as UC3
  usecase "סינון לפי לקוח / תאריך / סוג" as UC4
  usecase "הוספת עבודה דרך ה-Web" as UC5
  usecase "עריכת עבודה קיימת" as UC6
  usecase "מחיקת עבודה" as UC7
  usecase "ייצוא ל-Excel" as UC8
  usecase "ייבוא מ-Excel" as UC9
  usecase "סנכרון עם Google Sheets" as UC10
}

FieldWorker --> UC1
FieldWorker --> UC2
Manager --> UC3
Manager --> UC4
Manager --> UC5
Manager --> UC6
Manager --> UC7
Manager --> UC8
Manager --> UC9
UC1 ..> UC10 : <<include>>
UC5 ..> UC10 : <<include>>
UC6 ..> UC10 : <<include>>
UC7 ..> UC10 : <<include>>
UC10 --> GSheets

@enduml
